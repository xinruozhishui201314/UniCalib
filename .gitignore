# =============================================================================
# .gitignore - 排除大文件和构建产物
# =============================================================================

# Docker 构建产物
*.tar
*.tar.gz
docker/build.log

# OpenCV 预下载依赖（大文件，不纳入版本控制）
deps/opencv_deps/
!deps/opencv_deps/.gitkeep

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# ROS2 工作空间
*/build/
*/install/
*/log/

# 数据和结果
*.bag
*.db3
data/
results/
models/

# IDE 配置
.vscode/
.idea/
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb_checkpoints

# PyTorch 模型
*.pth
*.ckpt
*.pt

# 日志
*.log
logs/
